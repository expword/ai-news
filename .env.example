PORT=5179
HOST=127.0.0.1

# 后台接口保护。上线后务必改成一串随机字符。
ADMIN_TOKEN=change-me

# 大模型接口：支持 OpenAI-compatible /v1/chat/completions。
# 如果你的服务给的是完整 endpoint，也可以额外配置 LLM_ENDPOINT。
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com
LLM_MODEL=gpt-4.1-mini
LLM_ENDPOINT=

# 可选：真正联网搜索用。没有这些 key 时，后台仍会用 GitHub API 和预设信息源生成内容。
SEARCH_PROVIDER=
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
GITHUB_TOKEN=

# 可选：Python 后端会读取这些免费搜索/新闻 API，并交给大模型提取摘要。
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
NEWSAPI_KEY=
GNEWS_API_KEY=
NEWSDATA_API_KEY=
GUARDIAN_API_KEY=
CURRENTS_API_KEY=
WORLDNEWS_API_KEY=
MARKETAUX_API_KEY=
FREENEWSAPI_KEY=
NEWSDATAHUB_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# 定时任务使用服务器本地时区。你电脑当前是 Asia/Shanghai。
# 采集间隔（分钟）：每隔多久跑一次抓取+评分+精选。默认 10 分钟。
# 已采集过的 URL 不会重复送 LLM，所以高频采集成本可控；但仍会有抓取请求开销。
CRAWL_INTERVAL_MINUTES=10
# 每天几点把"昨天"的精选固化成带日期的日报存入归档（每日日报）。默认 0 点。
DAILY_REPORT_TIME=00:00
# 每周周报（GitHub / Skill）。WEEKLY_DAY：周一=1 … 周日=7。
WEEKLY_DAY=1
WEEKLY_TIME=09:30

# —— 自动推送到 GitHub（触发 Vercel 重新部署）——
# 在常驻运行的电脑上设为 1 开启：每次有新数据时自动 git 提交并推送。
AUTO_GIT_PUSH=0
# 推送节流：至少间隔多少分钟才推送一次，避免 Vercel 被频繁重新构建。默认 60 分钟。
GIT_PUSH_INTERVAL_MINUTES=60
# 推送到哪个远程/分支（默认 origin / main）。
GIT_REMOTE=origin
GIT_BRANCH=main

# —— 自动拉取代码 + 自重启（免手动同步）——
# 在常驻运行的电脑上设为 1 开启：定期 git pull，检测到 backend.py 变化时自动重启加载新代码。
# 这样在开发机改完代码 push 后，本机会自动跟上，无需手动 pull / 重启。
AUTO_GIT_PULL=0
# 拉取周期：至少间隔多少分钟拉一次。默认 5 分钟。
GIT_PULL_INTERVAL_MINUTES=5
